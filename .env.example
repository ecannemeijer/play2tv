#--------------------------------------------------------------------
# ENVIRONMENT - Copy this file to .env and fill in your values
#--------------------------------------------------------------------
CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# APP
# Set baseURL to your actual domain with trailing slash
#--------------------------------------------------------------------
app.baseURL = 'https://api.velixatv.com/'
app.forceGlobalSecureRequests = true
app.appTimezone = Europe/Amsterdam

#--------------------------------------------------------------------
# DATABASE
# Create a dedicated MySQL user with only the required privileges
#--------------------------------------------------------------------
database.default.hostname = localhost
database.default.database = play2tv
database.default.username = play2tv_user
database.default.password = CHANGE_ME_STRONG_DB_PASSWORD
database.default.DBDriver = MySQLi
database.default.port = 3306

#--------------------------------------------------------------------
# JWT SETTINGS
# Generate a strong random secret: openssl rand -base64 64
# NEVER share or commit this value!
#--------------------------------------------------------------------
jwt.secret = CHANGE_ME_JWT_SECRET_AT_LEAST_32_CHARACTERS_LONG_RANDOM_STRING
jwt.expiry = 31536000

#--------------------------------------------------------------------
# RATE LIMITING (login brute-force protection)
#--------------------------------------------------------------------
rateLimit.loginMaxAttempts = 5
rateLimit.loginWindowSeconds = 300

#--------------------------------------------------------------------
# CORS - Comma separated allowed origins (* for all, or specific domains)
#--------------------------------------------------------------------
cors.allowedOrigins = *

#--------------------------------------------------------------------
# LOGGING
# 1=emergency, 2=alert, 3=critical, 4=error, 5=warning, 6=notice, 7=info, 8=debug
#--------------------------------------------------------------------
logger.threshold = 4

#--------------------------------------------------------------------
# DIAGNOSTICS UPLOAD
# Add a private API key for support log uploads from the Android TV app.
#--------------------------------------------------------------------
diagnostics.uploadApiKey = CHANGE_ME_DIAGNOSTICS_UPLOAD_API_KEY
diagnostics.maxUploadBytes = 1048576

#--------------------------------------------------------------------
# TELEMETRY INGEST
# Public anonymous telemetry endpoint for the Android TV app.
# Tune these limits based on expected device volume.
#--------------------------------------------------------------------
telemetry.maxPayloadBytes = 131072
telemetry.maxRequestsPerMinute = 240
telemetry.maxEventsPerBatch = 100
telemetry.enabled = true
telemetry.sampleRate = 0.3
telemetry.batchSize = 20
telemetry.flushIntervalSec = 30

#--------------------------------------------------------------------
# REDIS DASHBOARD
# Use a dedicated Redis password and a unique WebSocket secret.
# The WebSocket URL can point directly to the Node service or to a reverse proxy.
#--------------------------------------------------------------------
redis.host = 127.0.0.1
redis.port = 6379
redis.password = CHANGE_ME_REDIS_PASSWORD
redis.database = 0
redis.connectTimeout = 1.5
redis.readTimeout = 1.5
redis.prefix = play2tv:
redis.scanCount = 200
redis.scanSampleLimit = 500
redis.keySearchLimit = 100
redis.slowlogLimit = 25
redis.keyDeleteEnabled = true
redis.admin.allowedCommands = ping,info,ttl,pttl,type,exists,get,hgetall,hget,llen,scard,zcard,memory_usage
redis.admin.flushablePrefixes = play2tv:,cache:,epg:,vod:
redis.iptv.userPrefixes = play2tv:session:,play2tv:user:session:,iptv:user:
redis.iptv.streamPrefixes = play2tv:stream:active:,iptv:stream:,stream:active:
redis.iptv.epgHitKeys = play2tv:metrics:epg:hits,metrics:epg:hits,cache:epg:hits
redis.iptv.vodHitKeys = play2tv:metrics:vod:hits,metrics:vod:hits,cache:vod:hits
redis.websocket.url = ws://127.0.0.1:8081
redis.websocket.secret = CHANGE_ME_LONG_RANDOM_WS_SECRET
redis.websocket.allowedOrigins = https://api.velixatv.com,https://dashboard.play2tv.nl
redis.websocket.intervalMs = 2000
redis.websocket.bindHost = 127.0.0.1
redis.websocket.bindPort = 8082
redis.websocket.path = /
